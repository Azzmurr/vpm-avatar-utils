            inline
            float2
            resolve_uv_bus(int uv_bus)
            {
                if (uv_bus == UV_BUS_UV0) return UV_BUSES.uv0;
                if (uv_bus == UV_BUS_UV1) return UV_BUSES.uv1;
                if (uv_bus == UV_BUS_UV3) return UV_BUSES.uv3;
                if (uv_bus == UV_BUS_UV4) return UV_BUSES.uv4;
                if (uv_bus == UV_BUS_UV5) return UV_BUSES.uv5;
                if (uv_bus == UV_BUS_UV6) return UV_BUSES.uv6;
                if (uv_bus == UV_BUS_UV7) return UV_BUSES.uv7;

                if (uv_bus == UV_BUS_PANOSPHERE) return UV_BUSES.panosphere;

                #if defined(VFGOO_ENABLE_UV_BUS_1)
                if (uv_bus == UV_BUS_1) return UV_BUSES.uv_bus_1;
                #endif

                #if defined(VFGOO_ENABLE_UV_BUS_2)
                if (uv_bus == UV_BUS_2) return UV_BUSES.uv_bus_2;
                #endif

                #if defined(VFGOO_ENABLE_UV_BUS_3)
                if (uv_bus == UV_BUS_3) return UV_BUSES.uv_bus_3;
                #endif

                #if defined(VFGOO_ENABLE_UV_BUS_4)
                if (uv_bus == UV_BUS_4) return UV_BUSES.uv_bus_4;
                #endif

                #if defined(VFGOO_ENABLE_UV_BUS_5)
                if (uv_bus == UV_BUS_5) return UV_BUSES.uv_bus_5;
                #endif

                #if defined(VFGOO_ENABLE_UV_BUS_6)
                if (uv_bus == UV_BUS_6) return UV_BUSES.uv_bus_6;
                #endif

                return UV_BUSES.uv0;
            }

            float2 apply_uv_tiling_offset_and_scroll(
                float2 uv,
                float2 tiling,
                float2 offset,
                float2 scroll,
                float time_base
            )
            {
                uv = uv * tiling + offset;

                uv += scroll * time_base.xx;

                return uv;
            }

            float4
            sample_texture_2d(
                const Texture2D tex,
                const float2 tiling,
                const float2 offset,
                const float2 scroll,
                const int uv_bus_to_use,
                const SamplerState samp,
                int time_base_slot
            )
            {
                // @InlinedTextureSampling
                float2 uv = resolve_uv_bus(uv_bus_to_use);

                float time_base = get_time(time_base_slot);
                uv = apply_uv_tiling_offset_and_scroll(uv, tiling, offset, scroll, time_base);

                float4 tap;
                if (IS_VERTEX_SHADER)
                {
                    tap = tex.SampleLevel(samp, uv, 0);
                }
                else
                {
                    tap = tex.Sample(samp, uv);
                }

                return tap;
            }

