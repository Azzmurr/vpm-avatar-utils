                #endif

                #if defined(VFGOO_ENABLE_MASK_MASSBLEND_2)
                if (info.channel == MASK_MASSBLEND_2) both_masks = MASK_CHANNELS.mass_blend_2;
                #endif

                if (info.channel == MASK_BACKFACE) both_masks = MASK_CHANNELS.backface;

                #if defined(VFGOO_ENABLE_MASK_DISTANCE_1)
                if (info.channel == MASK_DISTANCE_1) both_masks = MASK_CHANNELS.distance_1;
                #endif

                #if defined(VFGOO_ENABLE_MASK_DISTANCE_2)
                if (info.channel == MASK_DISTANCE_2) both_masks = MASK_CHANNELS.distance_2;
                #endif

                //float2 both_masks = MASK_CHANNELS.masks[info.channel];

                float mask = info.inverted ? both_masks.y : both_masks.x;

                // NOTE(valuef): https://www.desmos.com/calculator/mcgtyjntlf
