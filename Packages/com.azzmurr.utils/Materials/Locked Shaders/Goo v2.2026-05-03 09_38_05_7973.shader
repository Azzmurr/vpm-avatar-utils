                    #if defined(VFGOO_ENABLE_MASK_RIM_4)
                    MASK_CHANNELS.rim_4 = rim_mask_channel(_RimMask_4);
                    #endif


                    #undef rim_mask_channel
                }

                {
                    #define calc(_val) saturate(1-((_val) *2))

                    float2 value = float2(
                        calc(goo_noise),
                        calc(1-goo_noise)
                    );

                    MASK_CHANNELS.goo_noise = value;

                    #undef calc
                }

                MASK_CHANNELS.goo_drip = goo_drip;

                #define evaluate_capsule_mask_macro(_name) \
