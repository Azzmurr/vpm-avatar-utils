                #endif

                #if defined(VFGOO_ENABLE_MASK_TEXTURE_5)
                sample_mask_texture_macro(tex_5, _MaskChannel_5, _SamplerLinearRepeat);
                #endif

                #if defined(VFGOO_ENABLE_MASK_TEXTURE_6)
                sample_mask_texture_macro(tex_6, _MaskChannel_6, _SamplerLinearRepeat);
                #endif

                #if defined(VFGOO_ENABLE_MASK_TEXTURE_7)
                sample_mask_texture_macro(tex_7, _MaskChannel_7, _SamplerLinearRepeat);
                #endif

                #if defined(VFGOO_ENABLE_MASK_TEXTURE_8)
                sample_mask_texture_macro(tex_8, _MaskChannel_8, _SamplerLinearRepeat);
                #endif

                #undef sample_mask_texture_macro

                #if defined(VFGOO_ENABLE_MASK_DISTANCE_1)
                MASK_CHANNELS.distance_1 = evaluate_proximity_mask(
