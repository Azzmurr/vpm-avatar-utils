            // @DelayedGooDripEvaluationInVS
            // NOTE(valuef): We ignore the inverted mask on the MASK_GOO_DRIP mask in the VS because for
            // performance reasons we evaluate it in the middle of the VS and not immediatelly. This means that
            // the Mask_Channels is not fully initialized for half of the VS beacuse we pass it a bogus
            // placeholder value of 0. Now it works fine until you invert the mask, then you get some incorrect
            // results where the goo mask ends up being all white even when it shouldn't be (because we inverted
            // the 0 to a 1, duh!) and that's not desired. So, to prevent that undesired behaviour we set the goo
            // drip mask value to (0,0) and keep it that way until we have evaluated the goo drip, then we set
            // the proper value.
            // 2023-09-12

            float
            get_mask(
                Mask_Info info
            )
            {
                float2 both_masks = 0;

                if (info.channel == 0) return 1;

                #if defined(VFGOO_ENABLE_MASK_TEXTURE_1)
                if (info.channel == MASK_1_R) both_masks = MASK_CHANNELS.tex_1_r;
                if (info.channel == MASK_1_G) both_masks = MASK_CHANNELS.tex_1_g;
                if (info.channel == MASK_1_B) both_masks = MASK_CHANNELS.tex_1_b;
                if (info.channel == MASK_1_A) both_masks = MASK_CHANNELS.tex_1_a;
                #endif

                #if defined(VFGOO_ENABLE_MASK_TEXTURE_2)
                if (info.channel == MASK_2_R) both_masks = MASK_CHANNELS.tex_2_r;
                if (info.channel == MASK_2_G) both_masks = MASK_CHANNELS.tex_2_g;
                if (info.channel == MASK_2_B) both_masks = MASK_CHANNELS.tex_2_b;
                if (info.channel == MASK_2_A) both_masks = MASK_CHANNELS.tex_2_a;
                #endif

                #if defined(VFGOO_ENABLE_MASK_TEXTURE_3)
                if (info.channel == MASK_3_R) both_masks = MASK_CHANNELS.tex_3_r;
                if (info.channel == MASK_3_G) both_masks = MASK_CHANNELS.tex_3_g;
                if (info.channel == MASK_3_B) both_masks = MASK_CHANNELS.tex_3_b;
                if (info.channel == MASK_3_A) both_masks = MASK_CHANNELS.tex_3_a;
                #endif

                #if defined(VFGOO_ENABLE_MASK_TEXTURE_4)
                if (info.channel == MASK_4_R) both_masks = MASK_CHANNELS.tex_4_r;
                if (info.channel == MASK_4_G) both_masks = MASK_CHANNELS.tex_4_g;
                if (info.channel == MASK_4_B) both_masks = MASK_CHANNELS.tex_4_b;
