            inline float3 PreMultiplyAlpha(float3 diff_color, float alpha, float one_minus_reflectivity,
                             out float outModifiedAlpha)
            {
                bool is_transparent = false;

                EDITOR_BRANCH if (_RenderingMode == RENDERING_MODE_TRANSPARENT)
                {
                    // NOTE: shader relies on pre-multiply alpha-blend (_SrcBlend = One, _DstBlend = OneMinusSrcAlpha)

                    // Transparency 'removes' from Diffuse component
                    diff_color *= alpha;

                    // Reflectivity 'removes' from the rest of components, including Transparency
                    // outAlpha = 1-(1-alpha)*(1-reflectivity) = 1-(one_minus_reflectivity - alpha*one_minus_reflectivity) =
                    //          = 1-one_minus_reflectivity + alpha*one_minus_reflectivity
                    outModifiedAlpha = 1 - one_minus_reflectivity + alpha * one_minus_reflectivity;
                }
                else
                {
                    outModifiedAlpha = alpha;
                }

                return diff_color;
            }

            float3 UnpackScaleNormal(float4 packednormal, float bumpScale)
            {
                packednormal.x *= packednormal.w;

                float3 normal;
                normal.xy = (packednormal.xy * 2 - 1);
                normal.xy *= bumpScale;
                normal.z = sqrt(1.0 - saturate(dot(normal.xy, normal.xy)));

                return normal;
            }

