            float3
            Unity_GlossyEnvironment(
                UNITY_ARGS_TEXCUBE(tex),
                float4 hdr,
                float perceptual_roughness,
                float3 refl_uvw
            )
            {
                perceptual_roughness = perceptual_roughness * (1.7 - 0.7 * perceptual_roughness);

                float mip = perceptualRoughnessToMipmapLevel(perceptual_roughness);
                float4 rgbm = UNITY_SAMPLE_TEXCUBE_LOD(tex, refl_uvw, mip);

                return DecodeHDR(rgbm, hdr);
            }

