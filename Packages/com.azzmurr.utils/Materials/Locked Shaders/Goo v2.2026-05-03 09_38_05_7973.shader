            float3
            get_centered_camera_position()
            {
                #ifdef USING_STEREO_MATRICES
                return (unity_StereoWorldSpaceCameraPos[0] + unity_StereoWorldSpaceCameraPos[1]) * .5;
                #else
                return _WorldSpaceCameraPos.xyz;
