            //    8	    TEXCOORD	      4	              R8G8B8A8_UNORM	      0	          0	            False	        0
            //    9	    TEXCOORD	      5	              R8G8B8A8_UNORM	      0	          0	            False	        0
            //    10	  TEXCOORD	      6	              R8G8B8A8_UNORM	      0	          0	            False	        0
            //    11	  TEXCOORD	      7	              R8G8B8A8_UNORM	      0	          0	            False	        0
