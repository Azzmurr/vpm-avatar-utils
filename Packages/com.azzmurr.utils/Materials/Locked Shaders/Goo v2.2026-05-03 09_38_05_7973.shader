            struct Oscillator_Info
            {
                bool enabled;

                int slot;

                float4 default_value;
                float4 start;
                float4 end;
            };

            Oscillator_Info make_oscillator_info(bool enabled, int slot, float4 default_value, float4 start, float4 end)
            {
                Oscillator_Info ret;
                ret.enabled = enabled;
                ret.slot = slot;
                ret.default_value = default_value;
                ret.start = start;
                ret.end = end;
                return ret;
            }

