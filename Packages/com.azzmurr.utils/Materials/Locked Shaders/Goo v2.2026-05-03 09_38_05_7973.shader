            float AudioLinkGetVersion()
            {
                int2 dims;
                #if !defined(AUDIOLINK_STANDARD_INDEXING)
                _AudioTexture.GetDimensions(dims.x, dims.y);
                #else
                dims = _AudioTexture_TexelSize.zw;
                #endif

                if (dims.x >= 128)
                    return AudioLinkData(ALPASS_GENERALVU).x;
                else if (dims.x > 16)
                    return 1;
                else
                    return 0;
            }

