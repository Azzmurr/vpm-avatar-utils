      \
      MASK_CHANNELS._index##_r = make_texture_mask_channel_mask(tap.r, pre_inversion_strength, post_inversion_strength); \
      MASK_CHANNELS._index##_g = make_texture_mask_channel_mask(tap.g, pre_inversion_strength, post_inversion_strength); \
      MASK_CHANNELS._index##_b = make_texture_mask_channel_mask(tap.b, pre_inversion_strength, post_inversion_strength); \
      MASK_CHANNELS._index##_a = make_texture_mask_channel_mask(tap.a, pre_inversion_strength, post_inversion_strength); \
    }

                #if defined(VFGOO_ENABLE_MASK_TEXTURE_1)
                sample_mask_texture_macro(tex_1, _MaskChannel_1, _SamplerLinearRepeat);
