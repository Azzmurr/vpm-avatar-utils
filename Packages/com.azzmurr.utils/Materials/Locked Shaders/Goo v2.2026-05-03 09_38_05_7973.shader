            float3
            do_hsv_postprocessing(
                float3 col
            )
            {
                col = rgb2hsv(col);

                col.x = frac(
                    col.x + get_value(_PostProcessHSV_Hue_Shift_Osci) + _PostProcessHSV_Hue_Speed * get_time(
                        _PostProcessHSV_Hue_Speed_TimeBase));
                col.y = (col.y + get_value(_PostProcessHSV_Sat_Shift_Osci));
                col.z = (col.z + get_value(_PostProcessHSV_Value_Shift_Osci));

                col = hsv2rgb(col);

                return col;
            }


