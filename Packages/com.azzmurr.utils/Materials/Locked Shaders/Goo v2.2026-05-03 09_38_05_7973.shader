            // normal should be normalized, w=1.0
            float3
            sh_eval_l0_l1(
                float4 normal,
                float4 sh_r,
                float4 sh_g,
                float4 sh_b
            )
            {
                float3 x;

                // Linear (L1) + constant (L0) polynomial terms
                x.r = dot(sh_r, normal);
                x.g = dot(sh_g, normal);
                x.b = dot(sh_b, normal);

                return x;
            }

            // normal should be normalized, w=1.0
            float3
            sh_eval_l2(
                float4 normal,
                float4 sh_r,
                float4 sh_g,
                float4 sh_b,
                float3 sh_c
            )
            {
                float3 x1, x2;

                // 4 of the quadratic (L2) polynomials
                float4 vB = normal.xyzz * normal.yzzx;
                x1.r = dot(sh_r, vB);
                x1.g = dot(sh_g, vB);
                x1.b = dot(sh_b, vB);

                // Final (5th) quadratic (L2) polynomial
                float vC = normal.x * normal.x - normal.y * normal.y;
                x2 = sh_c.rgb * vC;

                return x1 + x2;
            }

            float4 sh_a_r;
            float4 sh_a_g;
            float4 sh_a_b;

            float4 sh_b_r;
            float4 sh_b_g;
            float4 sh_b_b;

            float3 sh_c;

            float3
            ShadeSHPerPixel(
                float3 normal,
                float3 ambient,
                float3 world_pos
            )
            {
                float3 ambient_contrib = 0.0;

                bool sample_l0_l1 = true;

                #if UNITY_LIGHT_PROBE_PROXY_VOLUME
                if (unity_ProbeVolumeParams.x == 1.0)
                {
                    ambient_contrib = SHEvalLinearL0L1_SampleProbeVolume(float4(normal, 1.0), world_pos);
                    sample_l0_l1 = false;
                }
                #endif

                if (sample_l0_l1)
                {
                    ambient_contrib = sh_eval_l0_l1(float4(normal, 1.0), sh_a_r, sh_a_g, sh_a_b);
                }

                ambient_contrib += sh_eval_l2(float4(normal, 1.0), sh_b_r, sh_b_g, sh_b_b, sh_c);

                ambient += max(float3(0, 0, 0), ambient_contrib);

                #ifdef UNITY_COLORSPACE_GAMMA
                ambient = LinearToGammaSpace(ambient);
                #endif

                return ambient;
            }

