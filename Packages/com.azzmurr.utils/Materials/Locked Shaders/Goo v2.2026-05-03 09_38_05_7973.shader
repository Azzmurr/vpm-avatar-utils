            struct Mask_Info
            {
                int channel;
                bool inverted;
                float strength;
                float contrast;
                float brightness;
            };

            Mask_Info
            make_mask_info(
                int channel,
                int inverted,
                float strength,
                float contrast,
                float brightness
            )
            {
                Mask_Info ret;
                ret.channel = channel;
                ret.inverted = inverted != 0;
                ret.strength = strength;
                ret.contrast = contrast;
                ret.brightness = brightness;
                return ret;
            }

